generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Produto {
  id         String   @id @default(cuid())
  nome       String
  estoque    Int      @default(0)
  precoMedio Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  entradas NotaEntrada[]
  saidas   NotaSaida[]
}

model NotaEntrada {
  id         String   @id @default(cuid())
  produtoId  String
  quantidade Int
  preco      Float
  dataNota   String
  referencia String?
  observacao String?
  createdAt  DateTime @default(now())

  produto Produto @relation(fields: [produtoId], references: [id])
}

model NotaSaida {
  id         String   @id @default(cuid())
  produtoId  String
  quantidade Int
  precoUnit  Float
  dataNota   String
  referencia String?
  observacao String?
  createdAt  DateTime @default(now())

  produto Produto @relation(fields: [produtoId], references: [id])
}
